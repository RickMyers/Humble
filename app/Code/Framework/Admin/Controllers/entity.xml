<controller name="entity" use="Twig" author="Rick Myers" email="rick@humbleprogramming.com">
    <actions blocking="ON" response="false">
        <action name="home" passalong="window_id">
            <description>The main page</description>
            <!-- Entity, Helper, Model, Conditional declarations begin here -->
        </action>

        <!-- ############################################################### -->

        <action name="list" output="JSON" response="true" passalong="window_id">
            <description>Lists the entities in our database</description>
            <model namespace='admin' class="system" method="listEntities" id="something">
                <parameter name="rows" optional="true" source="request" />
                <parameter name="page" optional="true" source="request" />
            </model>
        </action>
        
    </actions>
</controller>