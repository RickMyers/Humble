<?xml version="1.0"?>
<!--

Database tool controller

For Controller reference, please see "Anatomy of a Controller" at https://www.humbleprogramming.com/pages/Controllers.htmls
-->
<controller name="entity" use="Twig" author="Rick Myers" email="rick@humbleprogramming.com">
    <actions blocking="ON" response="false">
        
        <action name="home" passalong="window_id">
            <description>The main page</description>
            <!-- Entity, Helper, Model, Conditional declarations begin here -->
        </action>

        <!-- ############################################################### -->

        <action name="list" output="JSON" response="true" passalong="window_id">
            <description>Lists the entities in our database</description>
            <entity namespace='admin' rows='rows' page='page' class="users" method="entities" id="something">
            </entity>
        </action>
        
        <!-- ############################################################### -->       
        
        <action name="app" blocking="Off" passalong='window_id,tab_id'>
            <description>Individual instance of entity explorer app</description>
            <entity namespace="admin" class="users" assign="entities" method="listEntities" orderby="TABLE_NAME=ASC">
            </entity>
            
        </action>
        
        <!-- ############################################################### -->
        
        <action name="run" blocking="off">
            <description>Runs one or more queries</description>
        </action>
        
        <!-- ############################################################### -->
        
        <action name="save" blocking="off">
            <description>Saves a working query</description>
        </action>
        
        <!-- ############################################################### -->
        
        <action name="persist" blocking="off">
            <description>Persists a workspace</description>
        </action>
        
    </actions>
</controller>