<?xml version="1.0"?>
<!--

Admin Home Page Graph Stuff

For Controller reference, please see "Anatomy of a Controller" at https://www.humbleprogramming.com/pages/Controllers.htmls
-->
<controller name="graphs" use="Twig" author="Rick Myers" email="rick@humbleprogramming.com">
    <actions blocking="ON" response="false">
        <action name="cpu">
            <description>CPU Utilization Graph</description>
            <model namespace="admin" class="graph" id="source">
                <parameter name="data" source="post" format="json" required="true"  />
            </model>
        </action>

        <!-- ############################################################### -->

        <action name="dashboard">
            <description>Multiple Utilization Graphs</description>
            <model namespace="admin" class="graph" id="source">
                <parameter name="data" source="post" format="json" required="true"  />
            </model>
        </action>
    </actions>
</controller>