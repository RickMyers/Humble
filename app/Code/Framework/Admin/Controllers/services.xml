<?xml version="1.0"?>
<!--

Background Services tool

For Controller reference, please see "Anatomy of a Controller" at https://www.humbleprogramming.com/pages/Controllers.htmls
-->
<controller name="services" use="Twig" author="Rick Myers" email="rick@humbleprogramming.com">
    <actions blocking="Off" response="true">
        
        <action name="app" passalong="window_id">
            <description>The home page for the app</description>
            <model namespace="admin" id="services" class="services" />
        </action>
   
        <!-- ############################################################### -->
        
        <action name="list" blocking="Off" output="JSON">
            <description>Generates a list of installed services, whether they are running or not</description>
            <model namespace="admin" class="services" method="list" wrapper="json_encode" assign="services" />
        </action>

    </actions>
</controller>