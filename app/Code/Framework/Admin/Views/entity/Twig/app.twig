<style type="text/css">
    .zebra-table tr:nth-child(even) {
      background-color: #dadada;
    }
    .zebra-row {
         border: 1px solid transparent; opacity: .75
    }
    .zebra-row:hover {
        opacity: 1.0; border: 1px solid #777
    }
    .text-cell:hover {
        border: 1px solid #777
    }
</style>
<form nohref onsubmit="return false" class="explorer_form_{{ window_id }}_{{ tab_id }}">
    <div class="header_{{ window_id }}_{{ tab_id }} text-white align-right bg-[#333333] p-1">
        <div class="float-right">
        Context: <select name="context" class="text-gray-800 pt-1 pb-1">
                    <option value=""> </option>
                    {% for entity in entities %}
                        <option value="{{ entity }}"> {{ entity }} </option>
                    {% endfor %}
                </select>
        </div>
        <img class="workspace_{{ window_id }}_{{ tab_id }} cursor-pointer h-[24] inline-block" src="/images/admin/workspace.png" title="Save Workspace"/>  
        <div style="clear: both"></div>
    </div>
    <div class="query_{{ window_id }}_{{ tab_id }} p-1">
        <textarea id='query_space_{{ window_id }}_{{ tab_id }}' class="p2 w-full h-[300] text-mono" style="background-color: lightcyan; border: 1px solid #333; color: #333; font-size: .9em"></textarea>
    </div>
    <div class='query_controls_{{ window_id }}_{{ tab_id }} bg-[#333333]'>
        <div class="p-1 text-white inline-block">
            <img class="run_query_{{ window_id }}_{{ tab_id }} cursor-pointer h-[24] inline-block" src="/images/admin/play.png" title="Run Query"/> 
            <img class="save_query_{{ window_id }}_{{ tab_id }} cursor-pointer h-[24] inline-block" src="/images/admin/save.png" title="Save Query"/> 
        </div>
        <div id='entity_query_nav_{{ window_id }}_{{ tab_id }}' class='inline-block' style='vertical-align: bottom'>
        </div>
    </div>
    <div id='entity_tab_{{ window_id }}_{{ tab_id }}' class="entity_tab_{{ window_id }}_{{ tab_id }}">

    </div>
    <div id='query_results_tab_{{ window_id }}_{{ tab_id }}' class="query_results_tab_{{ window_id }}_{{ tab_id }}">
        <div id='query_results_{{ window_id }}_{{ tab_id }}' class="query_results_{{ window_id }}_{{ tab_id }} overflow-auto">
        </div>
        <div class="query_results_footer_{{ window_id }}_{{ tab_id }} p-1 bg-[#333333] text-white">
            <div class="float-left">
                Row <span id='results_{{ window_id }}_{{ tab_id }}_from_row'></span> to <span id='results_{{ window_id }}_{{ tab_id }}_to_row'></span> of <span id='results_{{ window_id }}_{{ tab_id }}_rows'></span>
            </div> 
            <div class="float-right">
                Page <span id='results_{{ window_id }}_{{ tab_id }}_page'></span> of <span id='results_{{ window_id }}_{{ tab_id }}_pages'></span> 
            </div>         
            <div class="text-center">
                <button> << </button>
                <button> < </button>
                <input type="text" class="w-12" style="background-color: lightcyan" v-bind:id="page" />
                <button> > </button>
                <button> >> </button>
            </div>
        </div>        
    </div>
</form>
<script type="text/javascript">
    ((win)=> {
        let explorer_form   = $('.explorer_form_{{ window_id }}_{{ tab_id }}').get(0);
        let explorer_nav    = $('#entity_explorer_nav_{{ window_id }}').height();
        let header          = $('.header_{{ window_id }}_{{ tab_id }}').get(0);
        let query           = $('.query_{{ window_id }}_{{ tab_id }}').get(0);
        let controls        = $('.query_controls_{{ window_id }}_{{ tab_id }}').get(0);
        let entity_tab      = $('.entity_tab_{{ window_id }}_{{ tab_id }}').get(0);
        let results_tab     = $('.query_results_tab_{{ window_id }}_{{ tab_id }}').get(0);     
        
        let qry_results     = $('.query_results_{{ window_id }}_{{ tab_id }}').get(0);
        let results_footer  = $('.query_results_footer_{{ window_id }}_{{ tab_id }}').get(0);          
        let query_space     = $('#query_space_{{ window_id }}_{{ tab_id }}').get(0);
        win._title('Entity Explorer');
        let tabs = new EasyTab('entity_query_nav_{{ window_id }}_{{ tab_id }}',120);
        tabs.add('Entities',null,'entity_tab_{{ window_id }}_{{ tab_id }}');
        tabs.add('Query Results',null,'query_results_tab_{{ window_id }}_{{ tab_id }}');
        tabs.tabClick(0);
        Humble.admin['entity'] = (!Humble.admin['entity']) ? {} : Humble.admin['entity'];
        Humble.admin['entity']['{{ window_id }}_{{ tab_id }}'] = Vue.createApp({
            template:   Humble.template('admin',"entity/list",true),
            app:        null,
            form:       explorer_form,
            data() {
                return {
                    win:        Desktop.window.list['{{ window_id }}'],
                    page:       1,
                    rows:       20,
                    pages:      0,
                    fromRow:    1,
                    toRow:      1,
                    totalRows:  1,
                    context:    [],
                    result:     {
                        rows:   20,
                        fromRow: 1,
                        toRow: 1,
                        totalRows: 1,
                        page:   1,
                        pages:  1
                    },
                    query:      query,
                    footer:     26,
                    header:     header,
                    controls:   controls,
                    list:       null,
                    window_id:  '{{ window_id }}',
                    tab_id:     '{{ tab_id }}',
                    entities:   [],
                    headers:    false,                    
                }
            },
            mounted() {
                this.list   = 'entity_list_'+this.window_id+'_'+this.tab_id;
                this.footer = 'entity_footer_'+this.window_id+'_'+this.tab_id;
                this.listEntities();
                this.win.resize(this.sizer).resize();
                new ResizeObserver(this.sizer).observe(query_space);
            },
            unmounted() {
                this.cleanup();
            },
            methods: {
                sizer() {
                    let h = this.win.content.height() - this.header.offsetHeight - this.controls.offsetHeight - this.query.offsetHeight - explorer_nav - $('#'+this.footer).height() - 4;
                    $('#'+this.list).height(h);
                },
                runQuery() {
                    (new EasyAjax('/admin/entity/run')).add().add().then((response) => {
                    }).post();
                },
                saveQuery() {
                    (new EasyAjax('/admin/entity/save')).add().add().then((response) => {
                    }).post();                    
                },
                saveWorkspace() {
                    (new EasyAjax('/admin/entity/workspace')).add().add().then((response) => {
                    }).post();                    
                },
                first() {
                    this.page = 1;
                    this.listEntities();
                },
                prev() {
                    if (this.page-- < 1) {
                        this.page = this.pages;
                    }
                    this.listEntities();                    
                },
                next() {
                    if (this.page++ > this.pages) {
                        this.page = 1;
                    }
                    this.listEntities();                    
                },
                last() {
                    this.page = this.pages;
                    this.listEntities();                    
                },
                pagination(p) {
                    this.totalRows  = p.rows.total;
                    this.fromRow    = p.rows.from;
                    this.toRow      = p.rows.to;
                    this.page       = p.pages.current;
                    this.pages      = p.pages.total;
                },
                listEntities() {
                    let app = this;
                    var ao  = new EasyAjax('/admin/entity/list') ;
                    ao.add('page',this.page).add('rows',this.rows).add('window_id',this.window_id).then((response)=>{
                        if (response) {
                            let entities = JSON.parse(response);
                            app.entities = entities;
                            let headers  = [];
                            for (var i in entities[0]) {
                                headers[headers.length] = i;
                            }
                            app.headers = headers;
                            app.pagination(ao.getPagination());
                        }
                    }).post();
                },
                cleanup() {
                    //maybe do something?
                }
            }          
        });
        Humble.admin['entity']['{{ window_id }}_{{ tab_id }}'].mount(entity_tab);
    })(Desktop.window.list['{{ window_id }}']);
      
</script>
