<div id="entity_explorer_nav_{{ window_id }}">
</div>
<script type="text/javascript">
    (()=> {
        let tabs = new EasyTab('entity_explorer_nav_{{ window_id }}',100,false);
        let f = ((tabs) => {
            console.log(tabs);
            return () => {
                let curTab = tabs.tabs[tabs.currentTab];
                console.log('curtab');
                console.log(tabs.currentTab);
                console.log(curTab);
                if (!curTab.loaded) {
                    (new EasyAjax('/admin/entity/app')).add('tab_id',tabs.currentTab).add('window_id','{{ window_id }}').then((response) => {
                        $(curTab.ref).html(response);
                        curTab.ref.style.display = 'block';
                        curTab.loaded            = true;
                    }).get();
                }
            }
        })(tabs);
        let g = (tab) => {
            tabs.add('Explorer',f,false);
            tabs.scaleTo(0);
            //tabs.tabClick(tabs.tabs.length-1);
        }
        tabs.add('<b>+</b> ',g,false,35);          
        tabs.add('Explorer',f,false);
      
        tabs.tabClick(0);
    })();
</script>