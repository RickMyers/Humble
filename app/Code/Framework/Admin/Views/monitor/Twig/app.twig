<script type="text/javascript"> 
    //This is for handling "multiplicity", as in multiple monitor apps open at one time
    Humble.admin['monitor'] = (!Humble.admin['monitor']) ? {} : Humble.admin['monitor'];
    Humble.admin['monitor']['{{ window_id }}'] = Vue.createApp({
        template: Humble.template('admin','monitor/app',true),
        app: "#system_monitor",
        data() {
                return {
                    window_id: "{{ window_id }}",
                    monitor_timer: null,
                    process_name: '',
                    start_icon: "{{ window_id }}-start-icon",
                    stop_icon:  "{{ window_id }}-stop-icon",
                    system: [
                
                    ],
                    processes: [
                        
                    ]
                }
            },
        mounted() {
            this.poll();
            let me = this;
            this.start_icon = document.getElementById('{{ window_id }}-start-icon');
            this.stop_icon  = document.getElementById('{{ window_id }}-stop-icon');
            $('#process-search-field').on("keydown",function (evt) {
                if (evt.keyCode == 13) {
                    me.process_name = evt.target.value;
                    window.clearTimeout(me.monitor_timer);
                    me.poll();
                }        
            });
        },
        unmounted() {
            window.clearTimeout(this.monitor_timer);
        },
        methods: {
            poll() {
                let me = this;
                console.log('Polling...');
                (new EasyAjax('/admin/monitor/status')).add('process_name',this.process_name).then((response) => {
                    let results = JSON.parse(response);
                    if (results) {
                        me.system        = results.system;
                        me.processes     = results.processes;
                        me.monitor_timer = window.setTimeout(this.poll,3000);
                    }
                }).post();
            },
            stopPolling() {
                $(this.stop_icon).css('display','none');
                $(this.start_icon).css('display','block');
                window.clearTimeout(this.monitor_timer);
            },
            startPolling() {
                $(this.start_icon).css('display','none');
                $(this.stop_icon).css('display','block');
                this.poll();
            },
            kill(pid) {
                let app = this;
                this.stopPolling();
                (new EasyAjax('/admin/monitor/kill')).add('pid',pid).then((response) => {
                    app.startPolling();
                }).post();
            }
        }
    });
    var win = Desktop.window.list['{{ window_id }}'];
    win._title('Process Monitor');
    Humble.admin['monitor']['{{ window_id }}'].mount('#'+win.content.id);
    win.resize(() => {
        $('#monitor_processes').height(win.content.height() - $E('monitor_status').offsetHeight - $E('monitor_footer').offsetHeight - 2);
    });
    win.close(((app) => {
        return function () {
            app.unmount();
        };
    })(Humble.admin['monitor']['{{ window_id }}']));
    

</script>