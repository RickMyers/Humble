{
    "form":
    {
            "id":           "fetch_secret_form",
            "drawme":       false,
            "action":       "",
            "method":       "post",
            "style":        "",
            "onenterkey":   "send"
    },
    "fields":
    [
        {
            "active":       true,
            "name":         "namespace",
            "longname":     "Namespace",
            "type":         "text",
            "onchange":     function (evt) {
                (new EasyAjax('/admin/secrets/list')).add('namespace',$(evt.target).val()).then((response) => {
                    var opts = [];
                    var res  = JSON.parse(response);
                    opts[opts.length] = { "text": "", "value":  "" };
                    for (var i=0; i<res.length; i++) {
                        opts[opts.length] = { "text": res[i].secret_name, "value":  res[i].id };
                    }
                    EasyEdits.populateSelectBox($('#fetch_secret_form [name=id]').get(0),opts);
                }).post();
            },
            "required":     true,
            "force":        true,
            "style":        ""
        },
        {
            "active":       true,
            "name":         "id",
            "longname":     "Secret Name",
            "title":        "Name of new secret",
            "type":         "select",
            "required":     true,
            "force":        true,
            onchange:       function (evt) {
                if (Edits['fetch-secret'].validate()) {
                    (new EasyAjax('/admin/secrets/view')).packageForm('fetch_secret_form').then((response) => {
                        if (response) {
                            response = JSON.parse(response);
                            $('#fetch_secret_form [name=secret_value]').val(response.secret);
                            $('#fetch_secret_form [name=update_secret_submit]').prop('disabled',false);
                        } else {
                            alert('Null returned from secret lookup');
                        }
                    }).post();
                }
            },
            "style":        ""
        },
        {
            "active":       true,
            "name":         "secret_value",
            "longname":     "Secret Value",
            "title":        "The value to store and encrypt",
            "type":         "text",
            "required":     false,
            "force":        false,
            "style":        ""
        }, 
        {
            "active":       true,
            "name":         "update_secret_submit",
            "longname":     "Update Button",
            "type":         "button",
            "disabled":     true,
            "style":        "",
            "value":        "",
            "class":        "",
            "onclick":      function () {
                (new EasyAjax('/admin/secrets/update')).packageForm('fetch_secret_form').add('secret_name',$('#fetch_secret_form [name=id]').children("option").filter(":selected").text()).then((response) => {
                    alert('Updated');
                }).post();
            }
        }
    ]
}

