<?xml version="1.0"?>
<!--

Basic Controller only used to route the person to the application home page

For Controller reference, please see "Anatomy of a Controller" at https://humbleprogramming.com/pages/Controllers.html
-->
<controller name="home" use="Smarty" author="Rick Myers " email="rick@humbleprogramming.com">
    <actions>
        
        <action name="page">
            <description>The Home Page</description>
            <helper namespace="humble" class="admin" id='appHomePage' />
        </action>

        <!-- ############################################################### -->
        
        <action name="index">
            <description>The default index.html page</description>
        </action>
        
        <!-- ############################################################### -->
        
        <action name="404">
            <description>The 'not found' page</description>
        </action>

        <!-- ############################################################### -->
        
        <action name="maint">
            <description>The 'site in maintenance mode' page</description>
        </action>
        
        <!-- ############################################################### -->

        <action name="register">
            <description>Register new user page</description>
        </action>
        
        <!-- ############################################################### -->

        <action name="recover" map="action">
            <description>The start recover password option</description>
            <if var="action" eq="action">
                <then>
                    <comment>Logic here should take email and send the email, then leave</comment>
                </then>
                <else>
                    <comment>If no 4th part of URI, then proceed to the actual start recovery page</comment>
                </else>
            </if>
        </action>        
    </actions>
</controller>