            type:           "select",
            required:       true,
            force:          true,
            onchange:       (evt) => {
                let component = $(evt.target).val();
                let namespace = $($('#test_form_&&id&& [name="namespace"]').get()[0]).val();
                if (component && namespace) {
                    (new EasyAjax('/workflow/method/list')).add('namespace',namespace).add('component',component).then((response) => {
                        EasyEdits.populateSelectBox($('#test_form_&&id&& [name="method"]').get()[0],JSON.parse(response));
