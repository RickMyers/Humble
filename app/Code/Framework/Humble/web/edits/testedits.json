            type:           "select",
            populator:      "/paradigm/namespace/list",
            required:       true,
            force:          true,
            classname:      "",
            onchange:       (evt) => {
                let val = $(evt.target).val();
                if (val) {
                    (new EasyAjax('/workflow/component/list')).add('namespace',val).then((response) => {
                        EasyEdits.populateSelectBox($('#test_form_&&id&& [name="component"]').get()[0],JSON.parse(response));
                    }).post();
                }
            },
            style:          "border: 1px solid #333; padding: 2px; width: 350px"
        },
        {
            active:         true,
            name:           "component",
            longname:       "Module Component",
