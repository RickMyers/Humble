<?xml version="1.0"?>
<!--

Namespace general actions

For Controller reference, please see "Anatomy of a Controller" at https://www.humbleprogramming.com/pages/Controllers.htmls
-->
<controller name="namespace" use="Twig" author="Rick Myers" email="rick@humbleprogramming.com">
    <actions blocking="Off" response="true">
        
        <action name="list" output="JSON">
            <description>List all Namespaces</description>
            <entity namespace="humble" orderby="namespace=ASC" class="modules" id="modules" />
        </action>

        <!-- ############################################################### -->

        <action name="active" output="JSON">
            <description>List all Namespaces</description>
            <entity namespace="humble" orderby="namespace=ASC" class="modules" id="modules" >
                <parameter name="enabled" source="request" default="Y" />
            </entity>
        </action>

    </actions>
</controller>