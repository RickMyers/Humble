({
	form:
	{
            id: 		"external-decision-form-&id&",
            drawme:		false,
            action:		"",
            onload:             function () { },
            method:		"post",
            style:		"",
            onenterkey:         "send"
	},
	fields:
	[
            {
                active:		true,
                name: 		"namespace",
                longname:	"Namespace",
                title:		"Choose a client or core for namespace",
                type:           "select",
                required:	true,
                force:          true,
                classname:	"",
                style:          "border-radius: 3px; padding: 3px; width: 400px; border: 1px solid #aaf",
                onchange:       (evt) => {
                    if (evt.target.value) {
                        (new EasyAjax('/workflow/external/components')).add('namespace',evt.target.value).then((response) => {
                            EasyEdits.populateSelectBox($('#external-decision-form-&id& [name=component]').get()[0],eval(response));
                        }).post();
                    }
                }                
            },
            {
                active:		true,
                name: 		"component",
                longname:	"Component to use",
                title:		"The object component",
                type:           "select",
                required:	true,
                force:		true,
                classname:	"",
                style:		"border-radius: 3px; padding: 3px; width: 400px; border: 1px solid #aaf",
                onchange:       (evt) => {
                    if (evt.target.value) {
                        (new EasyAjax('/workflow/external/methods')).add('decision','Y').add('namespace',$('#external-decision-form-&id& [name=namespace]').val()).add('component',evt.target.value).then((response) => {
                            EasyEdits.populateSelectBox($('#external-decision-form-&id& [name=method]').get()[0],eval(response));
                        }).post();
                    }
                }                
            },
            {
                active:		true,
                name: 		"method",
                longname:	"Function/Method",
                title:		"The function to execute",
                type:           "select",
                required:	true,
                force:		true,
                classname:	"",
                style:          "border-radius: 3px; padding: 3px; width: 400px; border: 1px solid #aaf",
                onchange:       (evt) => {
                    if (evt.target.value) {
                        var ao = new EasyAjax('/workflow/component/comment');
                        ao.add('namespace',$('#external-decision-form-&id& [name=namespace]').val());
                        ao.add('class',$('#external-decision-form-&id& [name=component]').val());
                        ao.add('method',evt.target.value);
                        ao.then((response) => {
                            if (response) {
                                $('#config-component-comment-&id&').css('display','block').html(response);
                            }
                        }).post();
                    }
                }                
            },
            {
                active:		true,
                name: 		"id",
                longname:	"Decision ID",
                title:		"",
                type:           "hidden",
                required:	true,
                force:		true,
                classname:	"",
                style:		""
            },
            {
                active:		true,
                name: 		"save-button",
                longname:	"Configure Save",
                title:		"Press to initially establish this workflow component",
                type:           "button",
                required:	false,
                force:		false,
                value:          "Save",
                classname:	"",
                style:		"font-size: 1em; padding: 2px 5px",
                onclick:        (evt) => {
                    if (Edits['decision_external_&id&'].validate()) {
                        $('#external-decision-form-&id&').submit();
                    }
                }                
            }
	]
})
