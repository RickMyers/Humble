({
    form:
    {
        id: 		"config-trigger-form-&id&",
        drawme:		false,
        action:		"",
        onload:     function () {
             var id = '&id&';
        },
        method:		"post",
        style:		"",
        onenterkey:	"send"
    },
    fields:
    [
        {
            active:             true,
            name: 		"namespace",
            longname:		"Namespace",
            title:		"Choose a client or core for namespace",
            onchange:           (evt) => {
                if (evt.target.value) {
                    (new EasyAjax('/workflow/component/events')).add('namespace',evt.target.value).then((response) => {
                        EasyEdits.populateSelectBox($('#config-trigger-form-&id& [name=trigger]').get(0),eval(response));
                    }).post();
                } 
            },
            type:               "select",
            required:		true,
            force:		true,
            classname:		"",
            style:		"border-radius: 3px; padding: 3px; width: 400px; border: 1px solid #aaf; color: #333"
        },
        {
            active:		true,
            name: 		"trigger",
            longname:		"Trigger Events",
            title:		"The event to listen for",
            type:               "select",
            required:		true,
            force:		true,
            onchange:           (evt) => {
            },
            classname:		"",
            style:		"border-radius: 3px; padding: 3px; width: 400px; border: 1px solid #aaf; color: #333"
        },
        {
            active:		true,
            name: 		"save-button",
            longname:		"Configure Save",
            title:		"Press to initially establish this workflow component",
            type:               "button",
            required:		false,
            force:		false,
            value:              "Save",
            onclick:            (evt) => {
                if (Edits['trigger_&id&'].validate()) {
                    $('#config-trigger-form-&id&').submit();
                }
            },
            classname:		"",
            style:		"font-size: 1em; padding: 2px 5px"
        }
    ]
})
