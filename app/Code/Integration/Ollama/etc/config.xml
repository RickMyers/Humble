<?xml version="1.0"?>
<config>
    <llama>
        <version>0.0.1</version>
        <title>Ollama<!-- This will appear in the administration screens for this module --></title>
        <description>The Ollama module<!-- This will appear in the admin page --></description>
        <author>
            <name>Rick Myers</name>
            <email>rick@humbleprogramming.com</email>
        </author>
        <module>
            <name>Ollama</name>
            <weight>50</weight>
            <required>N</required>
            <workflow>Y</workflow>
            <package>Integration</package>
            <use>Smarty</use>
        </module>
        <structure comment="This section describes the layout of your module, technically you can rearrange it anyway you want, but I would recommend just stick with the default structure below or you may encounter upgrading problems in the future">
            <models>
                <source>Ollama/Models</source>
            </models>
            <helpers>
                <source>Ollama/Helpers</source>
            </helpers>
            <controllers>
                <source>Ollama/Controllers</source>
                <cache>Ollama/Controllers/Cache</cache>
            </controllers>
            <mobile>
                <controllers>
                    <source>Ollama/Mobile/Controllers</source>
                    <cache>Ollama/Mobile/Controllers/Cache</cache>
                </controllers>
                <views>
                    <source>Ollama/Mobile/Views</source>
                    <cache>Ollama/Mobile/Views/Cache</cache>
                </views>
            </mobile>
            <schema>
                <install>Ollama/Schema/Install</install>
                <update>Ollama/Schema/Update</update>
                <layout>Ollama/Schema/DSL</layout>
            </schema>
            <resources>
                <sql>Ollama/Resources/sql</sql>
                <js>Ollama/Resources/js</js>
                <templates>Ollama/Resources/templates</templates>
            </resources>            
            <configuration>
                <source>Ollama/etc</source>
            </configuration>
            <views>
                <source>Ollama/Views</source>
                <cache>Ollama/Views/Cache</cache>
            </views>
            <images>
                <source>Ollama/Images</source>
                <cache>Ollama/Images/Cache</cache>
            </images>
            <entities>
                <source>Ollama/Entities</source>
            </entities>
            <RPC>
                <source>Ollama/RPC</source>
            </RPC>
            <frontend comment="will probably deprecate this...">
                <source>Ollama/web/app</source>
            </frontend>
        </structure>
        <extend comment="Means whether to look up the Module hierarchy if a specific class is not found (if not found in current module, perhaps the class is in a parent module)">
            <helpers>1</helpers>
            <models>1</models>
            <entities>1</entities>
        </extend>     
        <orm>
            <prefix>llama_</prefix>
            <mongodb>llama</mongodb>
            <!--
                Register your tables to be managed under this namespace in the entities section below in the following format:

                <table_name polyglot="Y' />

                The 'polyglot' attribute is optional.  Only specify when you are actually enabling the polyglot behavior
            -->
            <entities>

            </entities>
        </orm>
        <events>

        </events>
        <web>
            <!-- Edits are used for separating form validation from the form -->
            <edits>
                <edit1>Ollama/web/edits/edit.json</edit1>
            </edits>
            <hook>
                <!-- #################################################
                     This is where the JS lives for your module

                     Set the 'hook' name appropriately, and use as
                       many hooks as you'd like
                     #################################################    -->
                <js>
                    <source>Ollama/web/js/Ollama.js</source>
                </js>
                <css>
                    <source>Ollama/web/css/Ollama.css</source>
                </css>
            </hook>
        </web>
    </llama>
</config>